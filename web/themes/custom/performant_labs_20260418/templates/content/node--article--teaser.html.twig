{#
/**
 * @file
 * Custom override for article node teasers — uses dripyard_base:card so
 * field_image is visible on the /articles listing page.
 */
#}
{% set body_summary %}
  {% if node.body.summary %}
    {{ node.body.summary }}
  {% elseif content.body %}
    {{ content.body|render|striptags('<p>')|raw }}
  {% endif %}
{% endset %}

{{ include('dripyard_base:card', {
  title: label,
  image: content.field_image|default(''),
  href: url,
  byline: 'Read more',
  eyebrow_text: node.created.value|date('d M Y') ~ ' · Article',
  body: body_summary|default(' '),
}, with_context = false) }}
