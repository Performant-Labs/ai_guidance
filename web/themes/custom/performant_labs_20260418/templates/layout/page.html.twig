{#
/**
 * @file
 * Theme override for performant_labs_20260418.
 *
 * Inherits all behaviour from neonbyte/page.html.twig and adds a fixed
 * theme-indicator badge visible only to logged-in users.
 */
#}

<div aria-hidden="true" style="
  position: fixed;
  top: 8px;
  left: 8px;
  z-index: 999999;
  background: #4338ca;
  color: #fff;
  font: 600 11px/1 monospace;
  letter-spacing: .03em;
  padding: 4px 8px;
  border-radius: 4px;
  pointer-events: none;
  opacity: .88;
  box-shadow: 0 1px 4px rgba(0,0,0,.35);
">⚙ 20260418</div>

<div class="layout-container">

  {{ include('neonbyte:header', {
      header_first: page.header_first,
      header_second: page.header_second,
      header_third: page.header_third,
      attributes: header_attributes,
    }, with_context = false) }}

  {{ page.fixed_middle_right }}
  {{ page.fixed_bottom_right }}
  {{ page.highlighted }}

  <main class="site-main">
    <a id="main-content" tabindex="-1"></a>

    {{ include('@neonbyte/component-dev.html.twig', ignore_missing: true) }}

    {{ page.content }}
  </main>
  {% embed 'neonbyte:footer' with {
    footer_top: page.footer_top,
    footer_left: page.footer_left,
    footer_right: page.footer_right,
    footer_bottom: page.footer_bottom,
    theme: footer_theme,
  } only %}
    {% block footer_top_content %}
      {{- footer_top -}}
    {% endblock %}

    {% block footer_left_content %}
      {{- footer_left -}}
    {% endblock %}

    {% block footer_right_content %}
      {{- footer_right -}}
    {% endblock %}

    {% block footer_bottom_content %}
      {{- footer_bottom -}}
    {% endblock %}
  {% endembed %}
</div>
