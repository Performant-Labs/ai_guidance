{#
/**
 * @file
 * Interior documentation page template — two-column sidebar layout.
 *
 * Structure:
 * - Left sidebar  : `page.sidebar_first` region — documentation index / TOC menu.
 * - Right main    : `page.content` region — node body, standard Drupal blocks.
 *
 * The `.docs-layout` wrapper uses CSS Grid (defined in css/base.css under
 * `.docs-page .docs-layout`) to maintain the sidebar at a fixed width and
 * allow the content column to grow. Responsive: sidebar collapses below the
 * breakpoint defined in css/base.css.
 *
 * To assign a node to this template, add the content type or path alias
 * `documentation` to the node so Drupal's template suggestions can resolve it,
 * or use the theme's `.theme` file to add a template suggestion based on a
 * field, taxonomy term, or URL pattern.
 *
 * @see template_preprocess_page()
 * @see performant_labs_20260411.theme
 * @see css/base.css (.docs-page section)
 */
#}
<div class="layout-container">

  {{ include('neonbyte:header', {
      header_first: page.header_first,
      header_second: page.header_second,
      header_third: page.header_third,
      attributes: header_attributes,
    }, with_context = false) }}

  {{ page.fixed_middle_right }}
  {{ page.fixed_bottom_right }}
  {{ page.highlighted }}

  <main class="site-main docs-page">
    <a id="main-content" tabindex="-1"></a>

    <div class="docs-layout container">

      {% if page.sidebar_first %}
        <aside class="docs-sidebar" role="complementary" aria-label="Documentation navigation">
          {{ page.sidebar_first }}
        </aside>
      {% endif %}

      <div class="docs-content">
        {{ page.content }}
      </div>

    </div>
  </main>

  {% embed 'neonbyte:footer' with {
    footer_top: page.footer_top,
    footer_left: page.footer_left,
    footer_right: page.footer_right,
    footer_bottom: page.footer_bottom,
    theme: footer_theme,
  } only %}
    {% block footer_top_content %}
      {{- footer_top -}}
    {% endblock %}

    {% block footer_left_content %}
      {{- footer_left -}}
    {% endblock %}

    {% block footer_right_content %}
      {{- footer_right -}}
    {% endblock %}

    {% block footer_bottom_content %}
      {{- footer_bottom -}}
    {% endblock %}
  {% endembed %}
</div>
